# SmartTrade environment variables
# Copy to .env and set values as needed. Do not commit .env.

# Backend URL used by the browser (client-side).
# Local non-Docker dev:
#   NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
# Docker Compose:
#   NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
# VM / production:
#   NEXT_PUBLIC_BACKEND_URL=http://52.186.173.64:8000
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# Backend URL for Next.js API routes (server-side).
# Local non-Docker dev:
BACKEND_URL=http://127.0.0.1:8000
# Docker Compose overrides this internally to http://backend:8000.

# Massive API Key for Forex and Gold (Polygon-style)
MASSIVE_API_KEY=5twdPmXQm1VQhTIFnok2RCx4dZmS7c3u

# Backend AI engine configuration.
# Main backend will call the AI worker at this URL when Core Engine is enabled.
AI_ENGINE_URL=http://ai-engine:8010
CORE_ENGINE_USE_AI=true
AI_ENGINE_TIMEOUT_SECONDS=25
AI_ENGINE_REQUEST_TIMEOUT_SECONDS=20
AI_ENGINE_CANDLE_LIMIT=300
AI_ENGINE_NEWS_RESULTS_LIMIT=5
AI_ENGINE_SEARCH_RESULTS_LIMIT=4
AI_ENGINE_NEWS_LOOKBACK_DAYS=2

# Azure OpenAI configuration for backend AI analysis.
# Example endpoint:
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MODEL=gpt-5.3-codex
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Optional structured news source for the AI worker.
# If omitted, the AI worker falls back to live DuckDuckGo search/news.
NEWSAPI_KEY=
