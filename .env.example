# SmartTrade environment variables
# Copy to .env and set values as needed. Do not commit .env.

# Backend URL used by the browser (client-side). Required for charts and WebSocket.
# - Local Docker: use default from docker-compose (http://backend:8000) or leave unset.
# - VM / production: set to the public URL so the browser can reach the API, e.g.:
#   NEXT_PUBLIC_BACKEND_URL=http://52.186.173.64:8000
#   (Replace with your VM public IP or domain. No trailing slash.)
NEXT_PUBLIC_BACKEND_URL=http://backend:8000

# Backend URL for Next.js API routes (server-side). When using Docker Compose this is
# set in docker-compose.yml to http://backend:8000. Only set for local non-Docker dev.
# BACKEND_URL=http://127.0.0.1:8000

# Massive API Key for Forex and Gold (Polygon-style)
MASSIVE_API_KEY=your_massive_api_key_here
